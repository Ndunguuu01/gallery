pipeline {
  agent any

  stages {
    stage('Install Dependencies') {
      steps {
        sh 'npm install'
      }
    }
    stage('Test') {
      steps {
        sh 'npm test'
      }
    }
    stage('Build') {
      steps {
        sh 'npm run build'
      }
    }
    stage('Deploy') {
      steps {
        sh 'node server'
      }
    }
  }
  post {
    failure {
      mail to: 'bndungu061@gmail.com',
           subject: "Build failed: ${env.BUILD_NUMBER}",
           body: "Something is wrong with ${env.BUILD_URL}"
    }
    always {
      echo 'Pipeline finished.'
    }
  }
}
