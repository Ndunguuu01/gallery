pipeline {
  agent any

  stages {
    stage('Install Dependencies') {
      steps {
        sh 'npm install'
      }
    }
    stage('Test') {
      steps {
        sh 'npm test'
      }
    }
    stage('Build') {
      steps {
        sh 'npm run build'
      }
    }
    stage('Deploy') {
      steps {
        sh 'node server'
      }
    }
  }
  post {
    success {
      slackSend (channel: '#ip1', color: 'good', message: "Build successful: ${env.BUILD_NUMBER} - ${env.BUILD_URL}")
    }
    failure {
      slackSend (channel: '#ip1', color: 'danger', message: "Build failed: ${env.BUILD_NUMBER} - ${env.BUILD_URL}")
      mail to: 'you@example.com',
           subject: "Build failed: ${env.BUILD_NUMBER}",
           body: "Something is wrong with ${env.BUILD_URL}"
    }
    always {
      echo 'Pipeline finished.'
    }
  }
}
