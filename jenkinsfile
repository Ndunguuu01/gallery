pipeline {
    agent any

    stages {
        stage('Clone Repository') {
            steps {
                git "https://github.com/Ndunguuu01./gallery.git"
            }
        }
        stage('Install Dependencies') {
            steps {
                sh 'npm install'
            }
        }
        stage('Deploy to Render') {
            steps {
                sh 'node server.js'
            }
        }
    }
}
